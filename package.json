{
  "name": "telework-v1",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turso": "cross-env DB_PROVIDER=turso next dev",
    "build": "next build",
    "build:cloudflare": "opennextjs-cloudflare build",
    "build:aws": "cross-env DB_PROVIDER=turso next build",
    "preview": "opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare deploy",
    "start": "next start",
    "start:turso": "cross-env DB_PROVIDER=turso next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:d1": "npx wrangler d1 migrations apply telework-test --remote",
    "db:migrate:d1:local": "npx wrangler d1 migrations apply telework-test --local",
    "db:migrate:turso": "cross-env DB_PROVIDER=turso tsx src/db/migrate.ts",
    "check-processes": "powershell ./check-processes.ps1"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@libsql/client": "^0.17.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.2.2",
    "next": "16.2.0",
    "phosphor-react": "^1.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@next/env": "^16.2.0",
    "@opennextjs/cloudflare": "^1.17.3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.75.0"
  }
}
